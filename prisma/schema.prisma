generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  fullName    String   @map("full_name")
  phone       String?
  avatarUrl   String?  @map("avatar_url")
  address     String?
  city        String?
  district    String?
  postalCode  String?  @map("postal_code")
  role        Role     @default(USER)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders         Order[]
  userPackages   UserPackage[]
  deviceSessions DeviceSession[]

  @@map("users")
}

model Video {
  id           String   @id @default(uuid())
  title        String
  description  String?
  thumbnailUrl String?  @map("thumbnail_url")
  bunnyVideoId String   @map("bunny_video_id")
  duration     Int      @default(0)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  packageVideos PackageVideo[]

  @@map("videos")
}

model Package {
  id            String   @id @default(uuid())
  title         String
  description   String?
  slug          String   @unique
  price         Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @map("discount_price") @db.Decimal(10, 2)
  thumbnailUrl  String?  @map("thumbnail_url")
  isPublished   Boolean  @default(false) @map("is_published")
  isFeatured    Boolean  @default(false) @map("is_featured")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  packageVideos    PackageVideo[]
  orders           Order[]
  userPackages     UserPackage[]
  campaignPackages CampaignPackage[]

  @@map("packages")
}

model PackageVideo {
  packageId String  @map("package_id")
  videoId   String  @map("video_id")
  sortOrder Int     @default(0) @map("sort_order")

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  video   Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([packageId, videoId])
  @@map("package_videos")
}

model Order {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  packageId       String      @map("package_id")
  amount          Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  iyzicoPaymentId String?     @map("iyzico_payment_id")
  createdAt       DateTime    @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model UserPackage {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  packageId   String   @map("package_id")
  purchasedAt DateTime @default(now()) @map("purchased_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([userId, packageId])
  @@map("user_packages")
}

model DeviceSession {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  deviceFingerprint String   @map("device_fingerprint")
  deviceName        String?  @map("device_name")
  ipAddress         String?  @map("ip_address")
  isActive          Boolean  @default(true) @map("is_active")
  lastActiveAt      DateTime @default(now()) @map("last_active_at")
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_sessions")
}

model Campaign {
  id                 String   @id @default(uuid())
  title              String
  description        String?
  discountPercentage Int      @map("discount_percentage")
  bannerImageUrl     String?  @map("banner_image_url")
  startDate          DateTime @map("start_date")
  endDate            DateTime @map("end_date")
  isActive           Boolean  @default(true) @map("is_active")

  campaignPackages CampaignPackage[]

  @@map("campaigns")
}

model Book {
  id            String   @id @default(uuid())
  title         String
  description   String?
  slug          String   @unique
  price         Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @map("discount_price") @db.Decimal(10, 2)
  thumbnailUrl  String?  @map("thumbnail_url")
  isPublished   Boolean  @default(false) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("books")
}

model CampaignPackage {
  campaignId String @map("campaign_id")
  packageId  String @map("package_id")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  package  Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@id([campaignId, packageId])
  @@map("campaign_packages")
}
